<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
    <title>High Street Gym - Manage Sessions for Trainer</title>
</head>
<body>
    <%- include("partials/header.ejs", authenticatedUser) %>
    <h1>Manage Sessions</h1>
    <section class="main">
        <section>
            <button class="btn-large-regular"><a href="/session/trainer"><h4>Clear</h4></a></button>
            <form action="/session/<%= selectedSession.id %>" method="post"> 
                <section class="sec-small">
                    <input type="text" readonly name="id" id="id" value="<%= selectedSession.id %>" placeholder="Id" class="o-mini">
                    <select name="activityId" id="activityId" class="i-select-regular">
                        <option value="" selected disabled hidden>Select activity</option>
                        <% for (activity of activities) { %>
                            <option value="<%= activity.id %>" <%= selectedSession.activityId == activity.id ? "selected" : "" %>><%= activity.name %></option>
                        <% } %>
                    </select>   
                </section>
                <section class="sec-small">
                    <input type="text" name="date" id="date" value="<%= selectedSession.date %>" placeholder="Date" class="i-small">
                    <input type="text" name="time" id="time" value="<%= selectedSession.time %>" placeholder="Time" class="i-small">
                </section>
                <select name="locationId" id="locationId" class="i-select-large">
                    <option value="" selected disabled hidden>Select location</option>
                    <% for (location of locations) { %>
                        <option value="<%= location.id %>" <%= selectedSession.locationId == location.id ? "selected" : "" %>><%= location.name %></option>
                    <% } %>
                </select>
                <input type="hidden" name="trainerId" id="trainerId" value="<%= authenticatedUser.id %>">
    
                <% if (selectedSession.id == null) { %>
                    <input type="submit" name="action" value="Create" class="btn-large-regular">
                <% } else { %>
                    <section class="sec-small">
                        <input type="submit" name="action" value="Delete" class="btn-small-regular">
                        <input type="submit" name="action" value="Update" class="btn-small-medium">
                    </section>
                <% } %>
            </form>
        </section>
        <section>
            <article class="management-bg">
                <% if (sessionsWithDetails != null) { %>
                    <% for (sessionWithDetails of sessionsWithDetails) { %>
                        <section class="management-list">
                            <a href="/session/trainer/<%= sessionWithDetails.session.id %>">
                                <span>
                                    <p><%= sessionWithDetails.session.id %></p>
                                    <p><%= sessionWithDetails.activity.name %></p>
                                    <p><%= sessionWithDetails.session.date %></p>
                                    <p><%= sessionWithDetails.session.time %></p>
                                </span>
                            </a>
                        </section>
                    <% } %>
                <% } %>
            </article>
            
            <button class="btn-large-regular"><a href="/microblog"><h4>Back</h4></a></button>
        </section>
    </main>
</body>
</html>