<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE bookings [
    <!ELEMENT bookings (booking*)>
    <!ATTLIST bookings export-date CDATA "0000-00-00">
    <!ELEMENT booking (id, activity, date, time, location, trainer)>
    <!ELEMENT id (#PCDATA)>
    <!ELEMENT name (#PCDATA)>
    <!ELEMENT activity (name)>
    <!ELEMENT date (#PCDATA)>
    <!ELEMENT time (#PCDATA)>
    <!ELEMENT location (name)>
    <!ELEMENT trainer (name)>
    
]>
<bookings export-date="<%= date %>">
    <% for (const booking of bookings) { %>
    <booking>
        <id><%= booking.booking.id %></id>
        <activity>
            <name><%= booking.activity.name %></name>
        </activity>
        <date><%= booking.session.date %></date>
        <time><%= booking.session.time %></time>
        <location>
            <name><%= booking.location.name %></name>
        </location>
        <trainer>
            <name><%= booking.user.firstName %> <%= booking.user.lastName %></name>
        </trainer>
    </booking>
    <% } %>
</bookings>