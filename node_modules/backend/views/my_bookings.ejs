<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
    <title>High Street Gym - My Bookings</title>
</head>
<body>
    <%- include("partials/header.ejs", authenticatedUser) %> 
    <h1>My Bookings</h1>
    <section class="main">
        <section>
            <article class="large-list-bg">
                <% for (myBooking of bookings) { %>
                    <section class="my-bookings-list">
                        <section class="my-bookings-header">
                            <p><%= myBooking.session.date %> <%= myBooking.session.time %></p>
                            <form action="/booking/<%= myBooking.booking.id %>" method="post">
                                <input type="submit" name="action" value="X">
                                <input type="hidden" name="memberId" value="<%= myBooking.booking.memberId %>">
                                <input type="hidden" name="sessionId" value="<%= myBooking.booking.sessionId %>">
                            </form>
                        </section>
                        <section class="my-bookings-activity">
                            <h3><%= myBooking.activity.name %></h3>
                        </section>
                        <section class="my-bookings-details">
                            <p><%= myBooking.user.firstName %> <%= myBooking.user.lastName %></p>
                            <p><%= myBooking.location.name %></p>
                        </section>
                    </section>
                <% } %>
            </article>
            <button class="btn-large-regular"><a href="/microblog"><h4>Back</h4></a></button>
        </section>
    </section>
</body>
</html>