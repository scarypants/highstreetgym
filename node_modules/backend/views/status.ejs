<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
    <title>High Street Gym - Status</title>
</head>
<body>
    <header>
        <a href="/auth">
            <section class="sec-logo">
                <img src="\img\logo.png" alt="Logo" class="logo-img">
                <h3 class="logo">High Street Gym</h3>
            </section>
        </a>
    </header>
    <section class="main">
        <section class="sec-status">
            <h2><%= status %></h2>
            <% if (typeof message !== "undefined") { %>
                <p><%= message %></p>
            <% } %>
        </section>
    </main>
</body>
</html>