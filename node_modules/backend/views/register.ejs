<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
    <title>High Street Gym - Register</title>
</head>
<body>
    <section class="main">
        <section>
            <img src="/img/logo.png" alt="Logo" class="main-logo">
            <h1>Register</h1>
        </section>
        <section>
            <button disabled class="btn-large-regular"><a href="/microblog/guest"><h4>Sign in as a Guest</h4></a></button>
            <form action="/user" method="post">
                <section class="sec-small">
                    <input type="text" name="firstName" id="firstName" placeholder="First Name" class="i-small">
                    <input type="text" name="lastName" id="lastName" placeholder="Last Name" class="i-small">
                </section>
                <input type="text" name="email" id="email" placeholder="Email" class="i-large">
                <input type="password" name="password" id="password" placeholder="Password" class="i-large">
    
                <section class="sec-small">
                    <button disabled class="btn-small-regular"><a href="/auth"><h4>Back</h4></a></button>
                    <input class="btn-small-medium" type="submit" name="action" value="Sign Up">
                </section>
            </form>
        </section>
    </section>
</body>
</html>